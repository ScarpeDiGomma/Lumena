<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane
    prefHeight="600.0"
    prefWidth="900.0"
    styleClass="root-pane"
    stylesheets="@../CSS/auth.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.skbd.simulatore.controller.LoginController">

    <!-- Centered card -->
    <VBox
        alignment="CENTER"
        spacing="20.0"
        styleClass="login-card"
        AnchorPane.leftAnchor="0.0"
        AnchorPane.rightAnchor="0.0"
        AnchorPane.topAnchor="0.0"
        AnchorPane.bottomAnchor="0.0">

        <padding>
            <Insets top="48.0" right="48.0" bottom="48.0" left="48.0"/>
        </padding>

        <!-- App logo / title -->
        <Label
            text="LUMENA"
            styleClass="app-title">
            <font>
                <Font name="System Bold" size="36.0"/>
            </font>
        </Label>

        <Label
            text="LOGIN"
            styleClass="page-heading">
            <font>
                <Font name="System Bold" size="22.0"/>
            </font>
        </Label>

        <!-- Username field -->
        <VBox spacing="6.0" styleClass="field-group">
            <Label text="Username:" styleClass="field-label"/>
            <TextField
                fx:id="usernameField"
                promptText="Enter your username"
                styleClass="input-field"/>
        </VBox>

        <!-- Password field -->
        <VBox spacing="6.0" styleClass="field-group">
            <Label text="Password:" styleClass="field-label"/>
            <PasswordField
                fx:id="passwordField"
                promptText="Enter your password"
                styleClass="input-field"/>
        </VBox>

        <!-- Remember me -->
        <CheckBox
            fx:id="rememberMeCheckBox"
            text="Remember me"
            styleClass="remember-checkbox"/>

        <!-- Error label (hidden by default) -->
        <Label
            fx:id="errorLabel"
            styleClass="error-label"
            text=""
            visible="false"
            managed="false"/>

        <!-- Login button -->
        <Button
            fx:id="loginButton"
            text="LOGIN"
            styleClass="primary-button"
            onAction="#handleLogin"
            maxWidth="Infinity"/>

        <!-- Register link -->
        <HBox alignment="CENTER" spacing="4.0">
            <Label text="Don't have an account?" styleClass="link-text"/>
            <Hyperlink
                fx:id="registerLink"
                text="REGISTER"
                styleClass="nav-link"
                onAction="#handleGoToRegister"/>
        </HBox>

    </VBox>

</AnchorPane>
